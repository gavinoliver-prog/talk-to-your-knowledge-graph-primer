ex:Disease a rdfs:Class ;
    rdfs:label "Disease" .

ex:Drug a rdfs:Class ;
    rdfs:label "Drug" .

ex:Pathway a rdfs:Class ;
    rdfs:label "Pathway" .

ex:Protein a rdfs:Class ;
    rdfs:label "Protein" .

ex:Target a rdfs:Class ;
    rdfs:label "Target" .

ex:actionType a rdf:Property .

ex:actsOnTarget a rdf:Property ;
    rdfs:domain ex:Drug ;
    rdfs:range ex:Target .

ex:associatedWith a rdf:Property ;
    rdfs:domain ex:Protein ;
    rdfs:range ex:Disease .

ex:associationScore a rdf:Property .

ex:mechanismOfAction a rdf:Property .

ex:participatesIn a rdf:Property ;
    rdfs:domain ex:Protein ;
    rdfs:range ex:Pathway .

ex:targets a rdf:Property ;
    rdfs:domain ex:Drug ;
    rdfs:range ex:Protein .

ex:uniprotAccession a rdf:Property .

